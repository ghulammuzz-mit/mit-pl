# DNS Service
PORT=8080
CF_API_TOKEN=your-cloudflare-api-token
CF_ZONE_ID=your-cloudflare-zone-id

# Grafana (mcp-grafana, hpa-metrics)
GRAFANA_URL=https://your-grafana.example.com
GRAFANA_API_KEY=your-grafana-api-key

# Infisical (envctl, mcp-infisical)
INFISICAL_UNIVERSAL_AUTH_CLIENT_ID=your-infisical-client-id
INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET=your-infisical-client-secret
INFISICAL_HOST_URL=https://us.infisical.com
