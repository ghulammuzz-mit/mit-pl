# DNS Service
PORT=8080
CF_API_TOKEN=your-cloudflare-api-token
CF_ZONE_ID=your-cloudflare-zone-id

# Grafana (mcp-grafana, hpa-metrics)
GRAFANA_URL=https://your-grafana.example.com
GRAFANA_API_KEY=your-grafana-api-key

# Infisical (mcp-infisical, and runtime overrides for envctl)
# envctl normally uses credentials embedded at build time — these env vars
# override them when set (CI, per-user identities, local source builds).
INFISICAL_UNIVERSAL_AUTH_CLIENT_ID=your-infisical-client-id
INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET=your-infisical-client-secret
INFISICAL_HOST_URL=https://us.infisical.com

# envctl build-time embedding (Makefile / GitHub Actions only — not read at runtime).
# Set these when running `make envctl` or `make release-envctl` to bake creds into the binary.
# In CI these come from repo secrets of the same name.
INFISICAL_BUILD_CLIENT_ID=
INFISICAL_BUILD_CLIENT_SECRET=
INFISICAL_BUILD_SITE_URL=https://us.infisical.com
